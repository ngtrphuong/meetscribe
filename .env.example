# MeetScribe Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ── Security (REQUIRED) ─────────────────────────────────────
MEETSCRIBE_DB_KEY=change_this_to_a_secure_passphrase_min_32_chars

# ── Server ───────────────────────────────────────────────────
MEETSCRIBE_HOST=0.0.0.0
MEETSCRIBE_PORT=9876
MEETSCRIBE_ENV=development
MEETSCRIBE_LOG_LEVEL=INFO

# ── ASR Configuration ────────────────────────────────────────
MEETSCRIBE_DEFAULT_LANGUAGE=vi
MEETSCRIBE_ASR_LIVE_ENGINE=parakeet-vi
MEETSCRIBE_ASR_POST_ENGINE=vibevoice
MEETSCRIBE_VIBEVOICE_QUANTIZATION=4bit

# ── LLM Configuration ───────────────────────────────────────
MEETSCRIBE_LLM_PROVIDER=ollama
MEETSCRIBE_LLM_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434

# ── API Keys (Optional — for cloud fallback) ────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GOOGLE_GEMINI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
ALIBABA_QWEN_API_KEY=

# ── HuggingFace (Required for pyannote models) ──────────────
HUGGINGFACE_TOKEN=

# ── Docker ASR Microservice ──────────────────────────────────
WHISPER_ASR_HOST=localhost
WHISPER_ASR_PORT=9000
WHISPER_ASR_ENGINE=faster_whisper
WHISPER_ASR_MODEL=large-v3

# ── Data Paths ───────────────────────────────────────────────
MEETSCRIBE_DATA_DIR=./data
MEETSCRIBE_MODELS_DIR=./data/models
MEETSCRIBE_RECORDINGS_DIR=./data/recordings
